# Copiez ce fichier en `.env` et renseignez les valeurs.
# Le `.env` réel est ignoré par git (ne jamais le committer).

# --- Configuration Google (OAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Configuration Facebook (OAuth) ---
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# --- Configuration Apple (OAuth) ---
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=

# --- Environnement ---
DOMAIN_NAME=localhost:3000

# --- Mentions légales facturation (apparaissent sur les PDF arrhes + solde) ---
COMPANY_SIRET=
COMPANY_VAT_NUMBER=
COMPANY_CAPITAL=
COMPANY_ADDRESS=
COMPANY_EMAIL=

# --- Coordonnées bancaires (RIB sur les factures) ---
COMPANY_ACCOUNT_HOLDER=
COMPANY_IBAN=
COMPANY_BIC=

# --- Dropbox Sign (signature embarquée) ---
# DROPBOX_SIGN_API_KEY=
# DROPBOX_SIGN_CLIENT_ID=
# DROPBOX_SIGN_TEMPLATE_ID=
# DROPBOX_SIGN_TEST_MODE=true
# DROPBOX_SIGN_SIGNER_ROLE=locataire

# --- SMTP Gmail (mot de passe d'application) ---
GMAIL_SMTP_USERNAME=
GMAIL_SMTP_APP_PASSWORD=
MAILER_FROM=Chalet Mont Rose <exemple@gmail.com>
MAILER_OWNER_EMAIL=

# --- Swikly (caution en ligne) ---
SWIKLY_API_KEY=
SWIKLY_ACCOUNT_ID=
SWIKLY_API_SECRET=
SWIKLY_CALLBACK_URL=
SWIKLY_TEST_MODE=true
CAUTION_AMOUNT=1000
