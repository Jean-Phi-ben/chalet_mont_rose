#!/usr/bin/env bash
#
# Déploie le commit courant (HEAD) en STAGING sur jpserver.
#
# Instance isolée de la prod : conteneur dédié, port 8001, bases de données
# `chalet_mont_rose_staging*` (créées automatiquement au 1er lancement),
# volume de stockage dédié. Accès PRIVÉ via Tailscale : http://100.73.93.75:8001
#
# Sert à valider un déploiement avant de le passer en production (bin/deploy).
# Usage : bin/deploy-staging
#
set -euo pipefail

SERVER="jeanphi@100.73.93.75"
APP="chalet_mont_rose"
NAME="${APP}_staging"
PORT=8001
ENV_FILE="/home/jeanphi/.chalet_env"
HEALTH_URL="http://localhost:${PORT}/up"
REMOTE_NEW="/home/jeanphi/${NAME}_src"

say() { printf '\n\033[1;35m== %s ==\033[0m\n' "$*"; }
die() { printf '\n\033[1;31m✗ %s\033[0m\n' "$*" >&2; exit 1; }

cd "$(git rev-parse --show-toplevel)"
SHA="$(git rev-parse --short HEAD)"
say "STAGING — déploiement du commit ${SHA}"

# 1) Copie du code (HEAD) sur le serveur, en LF forcé.
say "Copie du code sur le serveur"
git -c core.autocrlf=false -c core.eol=lf archive --format=tar HEAD \
  | ssh "$SERVER" "rm -rf ${REMOTE_NEW} && mkdir -p ${REMOTE_NEW} && tar x -C ${REMOTE_NEW}"
ssh "$SERVER" "cp /home/jeanphi/${APP}/config/master.key ${REMOTE_NEW}/config/master.key"

# 2) Build de l'image staging.
say "Build de l'image staging"
ssh "$SERVER" "cd ${REMOTE_NEW} && docker build --network=host -t ${APP}:staging ."

# 3) (Re)lancement du conteneur staging. db:prepare crée les bases au 1er run.
say "(Re)lancement du conteneur staging (port ${PORT})"
ssh "$SERVER" bash -s <<EOF
set -e
docker rm -f ${NAME} 2>/dev/null || true
docker run -d --name ${NAME} --network host --restart unless-stopped \
  --env-file ${ENV_FILE} \
  -v ${NAME}_storage:/rails/storage \
  -e HTTP_PORT=${PORT} -e TARGET_PORT=3001 -e PORT=3001 \
  -e RAILS_ENV=production -e PGHOST=127.0.0.1 \
  -e DB_PRIMARY=${APP}_staging \
  -e DB_CACHE=${APP}_staging_cache \
  -e DB_QUEUE=${APP}_staging_queue \
  -e DB_CABLE=${APP}_staging_cable \
  ${APP}:staging
EOF

# 4) Healthcheck (jusqu'à 60s : le 1er run crée les bases + migre + seed).
say "Healthcheck ${HEALTH_URL}"
ok=0
for i in $(seq 1 30); do
  code="$(ssh "$SERVER" "curl -s -o /dev/null -w '%{http_code}' --max-time 5 ${HEALTH_URL}" 2>/dev/null || true)"; code="${code:-000}"
  printf '  tentative %2d → HTTP %s\n' "$i" "$code"
  [ "$code" = "200" ] && { ok=1; break; }
  sleep 2
done
[ "$ok" = "1" ] || die "Staging KO. Logs : ssh ${SERVER} 'docker logs --tail 50 ${NAME}'"

printf '\n\033[1;32m✓ Staging déployé : %s\033[0m\n' "$SHA"
printf '  → http://100.73.93.75:%s   (accès privé via Tailscale)\n' "$PORT"
printf '  Logs : ssh %s '"'"'docker logs -f %s'"'"'\n' "$SERVER" "$NAME"
