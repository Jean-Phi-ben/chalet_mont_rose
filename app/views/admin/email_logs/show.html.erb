<% content_for :title, "#{@email_log.label} — Admin" %>

<div class="mb-6">
  <%= link_to admin_email_logs_path, class: "text-xs text-stone-400 hover:text-stone-700" do %>
    <i class="fa-solid fa-arrow-left mr-1"></i> Retour au journal
  <% end %>
  <h1 class="text-2xl font-serif text-stone-900 tracking-wide mt-2" style="font-family: 'Playfair Display', serif;"><%= @email_log.subject %></h1>
  <p class="text-sm text-stone-500 mt-1"><%= @email_log.label %> · envoyé le <%= l(@email_log.sent_at, format: :long) rescue @email_log.sent_at %></p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-1 bg-white border border-stone-200 rounded-2xl p-6 space-y-4 text-sm">
    <div>
      <p class="text-[10px] text-stone-400 uppercase tracking-widest mb-1">De</p>
      <p class="text-stone-800 break-all"><%= @email_log.from_address %></p>
    </div>
    <div>
      <p class="text-[10px] text-stone-400 uppercase tracking-widest mb-1">À</p>
      <p class="text-stone-800 break-all"><%= @email_log.to_addresses %></p>
    </div>
    <% if @email_log.cc_addresses.present? %>
      <div>
        <p class="text-[10px] text-stone-400 uppercase tracking-widest mb-1">Cc</p>
        <p class="text-stone-800 break-all"><%= @email_log.cc_addresses %></p>
      </div>
    <% end %>
    <% if @email_log.booking %>
      <div>
        <p class="text-[10px] text-stone-400 uppercase tracking-widest mb-1">Réservation</p>
        <p>
          <%= link_to "##{@email_log.booking.id} · #{@email_log.booking.full_name}",
                admin_booking_path(@email_log.booking),
                class: "text-stone-800 hover:underline" %>
        </p>
      </div>
    <% end %>
    <% if @email_log.message_id.present? %>
      <div>
        <p class="text-[10px] text-stone-400 uppercase tracking-widest mb-1">Message-ID</p>
        <p class="text-xs text-stone-500 break-all"><%= @email_log.message_id %></p>
      </div>
    <% end %>
  </div>

  <div class="lg:col-span-2 bg-white border border-stone-200 rounded-2xl p-6">
    <h2 class="text-[11px] text-stone-400 uppercase tracking-widest mb-3">Pièces jointes</h2>
    <% if @email_log.attachments.attached? %>
      <ul class="divide-y divide-stone-100">
        <% @email_log.attachments.each do |att| %>
          <li class="py-3 flex items-center justify-between gap-3">
            <span class="text-sm text-stone-700 truncate">
              <i class="fa-regular fa-file text-stone-400 mr-2"></i><%= att.filename %>
            </span>
            <%= link_to "Télécharger", rails_blob_path(att, disposition: "attachment"),
                  class: "text-xs uppercase tracking-widest text-stone-700 hover:text-stone-900" %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-sm text-stone-400">Aucune pièce jointe.</p>
    <% end %>
  </div>
</div>
