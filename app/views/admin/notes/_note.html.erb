<% edit_params = {
     action: "notes#edit modal#open",
     notes_url_param: admin_note_path(note),
     notes_title_param: note.title,
     notes_body_param: note.body,
     notes_deadline_param: note.deadline&.iso8601
   } %>
<tr class="hover:bg-stone-50/60 transition">
  <!-- Case à cocher : tâche faite -->
  <td class="px-4 py-3 align-middle">
    <%= button_to toggle_admin_note_path(note), method: :patch,
          form: { class: "inline-flex" },
          class: "leading-none", aria: { label: note.done? ? "Marquer à faire" : "Marquer fait" } do %>
      <i class="fa-<%= note.done? ? "solid fa-square-check text-emerald-600" : "regular fa-square text-stone-300 hover:text-stone-500" %> text-lg transition"></i>
    <% end %>
  </td>

  <!-- Titre -->
  <td class="px-4 py-3">
    <button type="button" data-action="notes#edit modal#open"
            data-notes-url-param="<%= admin_note_path(note) %>"
            data-notes-title-param="<%= note.title %>"
            data-notes-body-param="<%= note.body %>"
            data-notes-deadline-param="<%= note.deadline&.iso8601 %>"
            class="text-left <%= note.done? ? "line-through text-stone-400" : "text-stone-800 hover:text-stone-950" %> transition">
      <%= note.title %>
    </button>
    <% if note.body.present? %>
      <p class="text-xs text-stone-400 mt-0.5 truncate max-w-xs"><%= note.body %></p>
    <% end %>
  </td>

  <!-- Date de création -->
  <td class="px-4 py-3 text-stone-500 text-xs whitespace-nowrap"><%= fr_date(note.created_at.to_date) %></td>

  <!-- Échéance (ouvre le calendrier dans le modal) -->
  <td class="px-4 py-3 whitespace-nowrap">
    <button type="button" data-action="notes#edit modal#open"
            data-notes-url-param="<%= admin_note_path(note) %>"
            data-notes-title-param="<%= note.title %>"
            data-notes-body-param="<%= note.body %>"
            data-notes-deadline-param="<%= note.deadline&.iso8601 %>"
            class="text-xs hover:underline">
      <% if note.deadline %>
        <span class="<%= note.overdue? ? "text-rose-600 font-medium" : "text-stone-600" %>">
          <i class="fa-regular fa-calendar mr-1"></i><%= fr_date(note.deadline) %>
        </span>
      <% else %>
        <span class="text-stone-300 hover:text-stone-500"><i class="fa-regular fa-calendar mr-1"></i>Définir…</span>
      <% end %>
    </button>
  </td>

  <!-- Actions -->
  <td class="px-4 py-3">
    <div class="flex items-center justify-end gap-3">
      <button type="button" data-action="notes#edit modal#open"
              data-notes-url-param="<%= admin_note_path(note) %>"
              data-notes-title-param="<%= note.title %>"
              data-notes-body-param="<%= note.body %>"
              data-notes-deadline-param="<%= note.deadline&.iso8601 %>"
              class="text-stone-500 hover:text-stone-900 text-xs uppercase tracking-widest">
        Détails
      </button>
      <%= button_to archive_admin_note_path(note), method: :patch,
            form: { class: "inline-flex" },
            class: "text-stone-400 hover:text-stone-700 transition",
            aria: { label: "Archiver" },
            data: { turbo_confirm: "Archiver cette note ?" } do %>
        <i class="fa-solid fa-box-archive text-sm"></i>
      <% end %>
    </div>
  </td>
</tr>
