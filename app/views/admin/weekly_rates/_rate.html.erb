<% fr_holiday = SchoolHolidays.france_for(rate.week_start) %>
<% ch_holiday = SchoolHolidays.geneva_for(rate.week_start) %>
<% tint = holiday_tint_style(france: fr_holiday, geneva: ch_holiday) %>
<tr id="<%= dom_id(rate) %>" class="<%= "hover:bg-stone-50/60" unless tint %>" style="<%= tint %>">
  <td class="px-5 py-3 text-stone-400 tabular-nums"><%= rate.week_start.cweek %></td>

  <td class="px-5 py-3 text-stone-800">
    <div>
      <%= fr_date(rate.week_start) %>
      <span class="text-stone-400">→ <%= fr_date(rate.week_start + 7) %></span>
    </div>
    <% if fr_holiday || ch_holiday %>
      <div class="mt-1 flex flex-wrap gap-1">
        <% if fr_holiday %>
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-blue-100 text-blue-700">FR · <%= fr_holiday[:label] %> · <%= fr_holiday[:zones].join("·") %></span>
        <% end %>
        <% if ch_holiday %>
          <span class="text-[10px] px-1.5 py-0.5 rounded bg-rose-100 text-rose-700">CH · <%= ch_holiday[:label] %></span>
        <% end %>
      </div>
    <% end %>
  </td>

  <td class="px-5 py-3">
    <%= form_with model: [:admin, rate], method: :patch, data: { controller: "autosubmit" } do |f| %>
      <div class="relative w-32">
        <%= f.number_field :price_euros, value: rate.price_euros, step: 1, min: 1,
              data: { action: "change->autosubmit#submit" },
              class: "w-full border border-stone-200 rounded-lg pl-3 pr-7 py-1.5 text-sm text-stone-800 font-medium focus:outline-none focus:border-stone-900 focus:ring-1 focus:ring-stone-900 transition" %>
        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-stone-400 text-sm">€</span>
      </div>
    <% end %>
  </td>

  <td class="px-5 py-3 text-stone-500"><%= money(rate.nightly_cents) %></td>

  <td class="px-5 py-3">
    <button type="button"
            data-action="note-editor#prepare modal#open"
            data-note-editor-url-param="<%= admin_weekly_rate_path(rate) %>"
            data-note-editor-note-param="<%= rate.note %>"
            data-note-editor-label-param="Semaine <%= rate.week_start.cweek %> · <%= fr_date(rate.week_start) %>"
            class="group inline-flex items-center gap-2 text-left max-w-[16rem] text-sm">
      <% if rate.note.present? %>
        <span class="text-stone-700 truncate"><%= rate.note %></span>
        <i class="fa-solid fa-pen text-[10px] text-stone-300 group-hover:text-stone-500 shrink-0"></i>
      <% else %>
        <span class="text-stone-300 italic group-hover:text-stone-500"><i class="fa-regular fa-note-sticky mr-1"></i>Ajouter…</span>
      <% end %>
    </button>
  </td>

  <td class="px-5 py-3">
    <div class="flex items-center justify-end">
      <%= button_to admin_weekly_rate_path(rate), method: :delete,
            form: { data: { turbo_confirm: "Supprimer ce tarif ?" } },
            class: "text-stone-300 hover:text-red-600 transition" do %>
        <i class="fa-solid fa-trash"></i>
      <% end %>
    </div>
  </td>
</tr>
