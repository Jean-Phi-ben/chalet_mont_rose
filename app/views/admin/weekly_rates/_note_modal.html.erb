<div id="note-modal"
     class="hidden fixed inset-0 z-[60]"
     role="dialog"
     aria-modal="true"
     aria-labelledby="note-modal-title"
     data-modal-target="root"
     data-action="click->modal#backdropClose">
  <div data-modal-target="backdrop"
       class="absolute inset-0 bg-stone-900/60 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>

  <div class="relative h-full w-full flex items-center justify-center p-4 pointer-events-none">
    <div data-modal-target="dialog"
         class="pointer-events-auto bg-white rounded-2xl shadow-2xl w-full max-w-md opacity-0 translate-y-4 scale-95 transition-all duration-300">
      <div class="px-6 pt-6 pb-4 border-b border-stone-100 flex items-start justify-between gap-4">
        <div>
          <p class="text-[10px] text-stone-400 uppercase tracking-[0.25em] mb-1">Note de tarif</p>
          <h3 id="note-modal-title" class="text-lg font-serif text-stone-900" data-note-editor-target="label">—</h3>
        </div>
        <button type="button" data-action="click->modal#close" aria-label="Fermer"
                class="w-9 h-9 rounded-full text-stone-500 hover:text-stone-900 hover:bg-stone-100 transition flex items-center justify-center shrink-0">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>

      <%= form_with url: "#", method: :patch, scope: :weekly_rate,
                    data: { "note-editor-target": "form", action: "turbo:submit-end->modal#close" },
                    class: "px-6 py-6 space-y-5" do |f| %>
        <div>
          <label class="block text-[10px] text-stone-400 uppercase tracking-widest mb-1.5">Note</label>
          <%= f.text_area :note, rows: 4, data: { "note-editor-target": "note" },
                placeholder: "Ex. vacances scolaires, minimum 2 semaines…",
                class: "w-full border border-stone-200 rounded-lg px-3 py-2.5 text-sm text-stone-700 focus:outline-none focus:border-stone-900 transition resize-none" %>
        </div>

        <div class="flex items-center justify-end gap-3">
          <button type="button" data-action="click->modal#close"
                  class="text-sm text-stone-500 hover:text-stone-900 uppercase tracking-widest py-2 px-4 transition">
            Annuler
          </button>
          <%= f.submit "Enregistrer",
                class: "bg-stone-900 text-white py-2.5 px-6 rounded-xl text-sm uppercase tracking-widest hover:bg-stone-800 transition cursor-pointer" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
