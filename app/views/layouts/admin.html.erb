<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — Chalet Mont Rose" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  </head>

  <body class="bg-stone-100 min-h-screen" style="font-family: 'Lato', sans-serif;">
    <!-- Barre admin -->
    <header class="bg-white border-b border-stone-200 sticky top-0 z-40">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between gap-4">
        <%= link_to admin_root_path, class: "flex items-center gap-2" do %>
          <span class="text-lg tracking-[0.15em] uppercase text-stone-800 font-light" style="font-family: 'Playfair Display', serif;">
            Chalet Mont Rose
          </span>
          <span class="text-[10px] uppercase tracking-widest bg-stone-900 text-white px-2 py-0.5 rounded-full">Admin</span>
        <% end %>

        <nav class="hidden sm:flex items-center gap-6 text-xs tracking-widest uppercase text-stone-500">
          <%= link_to "Tableau de bord", admin_root_path, class: "hover:text-stone-900 transition" %>
          <%= link_to "Réservations", admin_bookings_path, class: "hover:text-stone-900 transition" %>
          <%= link_to "Factures", admin_invoices_path, class: "hover:text-stone-900 transition" %>
          <%= link_to "Tarifs", admin_weekly_rates_path, class: "hover:text-stone-900 transition" %>
          <%= link_to "Paramètres", admin_booking_setting_path, class: "hover:text-stone-900 transition" %>
        </nav>

        <div class="flex items-center gap-4">
          <%= link_to root_path, class: "text-xs text-stone-400 hover:text-stone-700 transition" do %>
            <i class="fa-solid fa-arrow-up-right-from-square mr-1"></i> Voir le site
          <% end %>
          <% if authenticated? %>
            <%= button_to session_path, method: :delete, class: "text-xs text-red-600 hover:text-red-700 transition" do %>
              <i class="fa-solid fa-arrow-right-from-bracket mr-1"></i> Déconnexion
            <% end %>
          <% end %>
        </div>
      </div>
    </header>

    <%= render "shared/flashes" %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8">
      <%= yield %>
    </main>
  </body>
</html>
