<% start_day  = month.beginning_of_month.beginning_of_week(:monday) %>
<% last_day   = month.end_of_month.end_of_week(:monday) %>
<% blocked    = Booking.blocked_dates_between(start_day, last_day) %>
<% transition = Booking.transition_dates_between(start_day, last_day) %>

<div>
  <p class="font-serif text-lg text-stone-900 capitalize text-center mb-3"><%= fr_month_year(month) %></p>

  <div class="grid grid-cols-7 gap-1">
    <% (start_day..last_day).each do |day| %>
      <% in_month       = day.month == month.month %>
      <% nightly        = Pricing.nightly_cents_for(day) %>
      <% past           = day < Date.current %>
      <% fully_blocked  = blocked.include?(day) %>
      <% is_transition  = transition.include?(day) && !fully_blocked %>
      <% clickable      = in_month && !past && !fully_blocked %>
      <% tooltip = if fully_blocked && in_month
                     "Semaine déjà réservée"
                   elsif is_transition && in_month
                     "Jour de transition — utilisable comme arrivée OU départ d'une autre réservation"
                   elsif clickable && !day.saturday?
                     "Sélectionne le samedi de la semaine"
                   end %>
      <div class="relative aspect-square rounded-lg p-1 flex flex-col items-center justify-center text-center select-none border
                  <%= in_month ? 'border-stone-100' : 'border-transparent opacity-30' %>
                  <%= 'cursor-pointer hover:border-stone-400' if clickable %>
                  <%= 'bg-stone-100' if fully_blocked && in_month %>"
           <% if in_month %>data-calendar-target="day" data-date="<%= day.iso8601 %>"<% end %>
           <% if clickable %>data-action="click->calendar#pick"<% end %>
           <% if tooltip %>title="<%= tooltip %>"<% end %>>
        <% if is_transition && in_month %>
          <%# Bandeau gradient diagonal qui indique la transition (chalet libre une demi-journée) %>
          <span class="absolute inset-0 rounded-lg pointer-events-none"
                style="background: linear-gradient(135deg, #f5f5f4 0%, #f5f5f4 50%, transparent 50%, transparent 100%);"></span>
        <% end %>
        <span class="relative text-xs <%= fully_blocked && in_month ? 'line-through decoration-2 decoration-stone-500 text-stone-400' : (past ? 'text-stone-300 line-through' : 'text-stone-700') %>"><%= day.day %></span>
        <% if nightly && in_month && !fully_blocked && !past %>
          <span class="relative text-[9px] text-stone-400 leading-none mt-0.5"><%= money(nightly) %></span>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
