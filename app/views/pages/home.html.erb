<% content_for :full_width do %>
  <div class="relative h-[45vh] md:h-[900px] w-full overflow-hidden">
    <%= image_tag "chalet_main.jpg", class: "absolute inset-0 w-full h-full object-cover object-center" %>

    <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent flex flex-col items-center justify-end text-center px-4 pb-12 md:pb-20">
      <h1 class="text-white uppercase text-[28px] md:text-[50px] font-serif font-light tracking-[0.30em] drop-shadow-2xl leading-tight">
        Chalet Mont Rose
      </h1>
      
      <p class="text-white text-[14px] md:text-[22px] font-extralight tracking-[0.3em] drop-shadow-md mt-4 opacity-90">
        L'exception au sommet des Alpes
      </p>
    </div>
  </div>
<% end %>

<div id="gallery" class="max-w-7xl mx-auto py-16 px-4">
  <h2 class="text-3xl font-serif font-bold text-slate-900 mb-8">Galerie de Prestige</h2>

  <div
    data-carousel='{ "loadingClasses": "opacity-0", "dotsItemClasses": "carousel-dot carousel-active:bg-primary", "slidesQty": { "xs": 1, "lg": 3 }, "isCentered": true, "isSnap": true }'
    class="relative w-full"
  >
    <div class="carousel overflow-y-auto flex h-80 snap-x snap-mandatory overflow-x-auto">
      <div class="carousel-body h-full gap-4 opacity-0">
        <!-- Slide 1 : Le Grand Salon -->
        <div class="carousel-slide snap-center">
          <div class="h-full overflow-hidden rounded-2xl shadow-md">
            <%= image_tag "salon.jpg", class: "w-full h-full object-cover hover:scale-105 transition duration-500" %>
          </div>
        </div>
        <!-- Slide 2 : Suites de Maitre -->
        <div class="carousel-slide snap-center">
          <div class="h-full overflow-hidden rounded-2xl shadow-md">
            <%= image_tag "chambre.jpg", class: "w-full h-full object-cover hover:scale-105 transition duration-500" %>
          </div>
        </div>
        <!-- Slide 3 : Panorama Alpin -->
        <div class="carousel-slide snap-center">
          <div class="h-full overflow-hidden rounded-2xl shadow-md">
            <%= image_tag "vue.jpg", class: "w-full h-full object-cover hover:scale-105 transition duration-500" %>
          </div>
        </div>
        <!-- Slide 4 : Espace Bien-etre -->
        <div class="carousel-slide snap-center">
          <div class="h-full overflow-hidden rounded-2xl shadow-md">
            <%= image_tag "spa.jpg", class: "w-full h-full object-cover hover:scale-105 transition duration-500" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Previous Slide -->
    <button type="button" class="carousel-prev start-5 max-sm:start-3 carousel-disabled:opacity-50 size-9.5 bg-base-100 flex items-center justify-center rounded-full shadow-base-300/20 shadow-sm">
      <span class="icon-[tabler--chevron-left] size-5 cursor-pointer"></span>
      <span class="sr-only">Previous</span>
    </button>
    <!-- Next Slide -->
    <button type="button" class="carousel-next end-5 max-sm:end-3 carousel-disabled:opacity-50 size-9.5 bg-base-100 flex items-center justify-center rounded-full shadow-base-300/20 shadow-sm">
      <span class="icon-[tabler--chevron-right] size-5"></span>
      <span class="sr-only">Next</span>
    </button>

    <div class="carousel-pagination absolute bottom-3 end-0 start-0 flex justify-center gap-3"></div>
  </div>
</div>
